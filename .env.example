# TDS Edge Node Configuration
# Copy to .env and fill in values

# Node identity
TDS_NODE_ID=node-01
TDS_NODE_REGION=eu
TDS_ENVIRONMENT=production
TDS_PORT=8100

# Auth (REQUIRED in production: must match CF Worker's TDS_SECRET_KEY)
TDS_SECRET_KEY=

# Central server (for config sync — leave empty for standalone mode)
TDS_CENTRAL_URL=
TDS_CENTRAL_API_KEY=

# Observability (optional)
TDS_SENTRY_DSN=
