# Edge-node .env TEMPLATE (F.32) — documents the canonical key set written by
# render-env.sh. PLACEHOLDER VALUES ONLY — never put real secrets here (this
# file is part of the PUBLIC mirror via `git subtree push`). The real .env is
# rendered on the node at provision time and is gitignored (see .gitignore).
TDS_NODE_ID=<node-id>                       # e.g. au-syd1
TDS_NODE_REGION=<region>                    # eu | us | au | ca | as
TDS_ENVIRONMENT=production                  # production | staging | local
TDS_PORT=8100
CADDY_DOMAIN=<api-node.base-domain>         # e.g. api-au.adstudy.dev
TDS_SECRET_KEY=<shared-edge-secret>         # X-TDS-Key shared with Worker + central
TDS_TDS_SECRET_KEY=<same-as-TDS_SECRET_KEY> # pydantic env_prefix double-write
TDS_CENTRAL_URL=https://<api-collector-host>  # MUST be https + CF-proxied (F.32 T0)
TDS_CENTRAL_API_KEY=<same-as-TDS_SECRET_KEY>  # collector auth (Q5: == secret_key)
TDS_SMOKE_PROBE_SECRET=<hmac-secret-or-empty> # TD-13 smoke-probe HMAC; empty = fail-open
TDS_SENTRY_DSN=<geo-tds-backend-dsn-or-empty>
TDS_DIAG_TRACES_BOOST=false
TDS_DIAG_OBS_STREAM=false
TDS_DIAG_VERBOSE_LOGS=false
TDS_CODE_VERSION=<git-sha>                   # stamped by render-env / update.sh
